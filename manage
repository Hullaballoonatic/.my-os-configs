#!/usr/bin/env bash
set -euo pipefail

COMMAND="${1:-apply}"
LOCAL_HOST=$(hostname)
TARGET="${2:-$LOCAL_HOST}"
SCRIPT_PATH="${BASH_SOURCE[0]}"

while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"

  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done

REPO_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

OS="$(uname -s | tr '[:upper:]' '[:lower:]')"

log() {
  printf '[dotfiles] %s\n' "$*" >&2
}

abort() {
  printf '[dotfiles] ERROR: %s\n' "$*" >&2
  exit 1
}

has() {
  command -v "$1" >/dev/null 2>&1
}

ensure_nix() {
  if command -v nix >/dev/null 2>&1; then
    return
  fi

  log "Installing Nix..."
  sh <(curl --proto '=https' --tlsv1.2 -L https://nixos.org/nix/install) --daemon
}

darwin() {
  local casks=(
    ghostty
  )

  log "Updating Homebrew..."
  brew update

  log "Installing casks: ${casks[*]}"

  brew install --cask "${casks[@]}"

  ensure_nix

  log "Installing nix packages"
  nix profile add "$REPO_DIR/nix" --extra-experimental-features 'nix-command flakes'
}

nixos() {
  log "Rebuilding NixOS configuration for $TARGET..."

  local flake="$REPO_DIR/nix#$TARGET"

  case "$LOCAL_HOST:$TARGET" in
    desktop:desktop)
      sudo nixos-rebuild switch --flake "$flake"
      ;;

    desktop:pi)
      nixos-rebuild switch --flake "$flake" --target-host casey@pi.local --sudo 
      ;;

    pi:*)
      sudo nixos-rebuild switch --flake "$flake" --build-host casey@desktop.local
      ;;

    *)
      abort "Unsupported rebuild path: local=$LOCAL_HOST target=$TARGET"
      ;;
  esac
}

build() {
  case "$OS" in
    darwin) darwin ;;
    linux) nixos ;;
    *) abort "Unsupported OS: $OS" ;;
  esac

  apply
}

dotfile_name() {
  local name="$1"
  printf '%s\n' "${name/#dot-/.}"
}

stow_target_path() {
  local rel="$1"
  local out=""
  local part

  IFS=/ read -ra parts <<< "$rel"

  for part in "${parts[@]}"; do
    [[ -n "$out" ]] && out+="/"
    out+="$(dotfile_name "$part")"
  done

  printf '%s/%s\n' "$HOME" "$out"
}

remove_conflicting_symlinks() {
  local dir="$1"
  local source_root="$dir"
  local source target rel source_real target_real

  [[ -d "$source_root" ]] || return 0

  while IFS= read -r -d '' source; do
    rel="${source#"$source_root"/}"
    target="$(stow_target_path "$rel")"

    [[ -L "$target" ]] || continue

    source_real="$(readlink -f "$source" 2>/dev/null || true)"
    target_real="$(readlink -f "$target" 2>/dev/null || true)"

    if [[ -z "$target_real" || "$source_real" != "$target_real" ]]; then
      log "Removing conflicting symlink: $target -> $(readlink "$target")"
      rm "$target"
    fi
  done < <(find "$source_root" \( -type f -o -type l \) -print0)
}

apply() {
  for package in common "$OS"; do
    [[ -d "$REPO_DIR/stow/$package" ]] || continue

    log "Preparing $package"
    remove_conflicting_symlinks "$REPO_DIR/stow/$package"

    log "Stowing $package"
    stow -d "$REPO_DIR/stow" -t "$HOME" -R --no-folding --dotfiles --adopt "$package"
  done

  log "Apply complete."
}

update() {
  case "$OS" in
    linux)
      log "Updating NixOS flake..."
      nix flake update --flake "$REPO_DIR/nix"

      nixos
      ;;
    *)
      has topgrade || abort "topgrade is not installed."
      topgrade
      ;;
  esac

  log "Update complete."
}

case "$COMMAND" in
  build) build ;;
  apply) apply ;;
  update) update ;;
  *) abort "Usage: $0 [build|apply|update]" ;;
esac

