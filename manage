#!/usr/bin/env bash
set -euo pipefail

COMMAND="${1:-upgrade}"
LOCAL_HOST=$(hostname)
TARGET="${2:-$LOCAL_HOST}"
SCRIPT_PATH="${BASH_SOURCE[0]}"

while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"

  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done

REPO_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

OS="$(uname -s | tr '[:upper:]' '[:lower:]')"

log() {
  printf '[dotfiles] %s\n' "$*" >&2
}

abort() {
  printf '[dotfiles] ERROR: %s\n' "$*" >&2
  exit 1
}

has() {
  command -v "$1" >/dev/null 2>&1
}

ensure_nix() {
  if command -v nix >/dev/null 2>&1; then
    return
  fi

  log "Installing Nix..."
  sh <(curl --proto '=https' --tlsv1.2 -L https://nixos.org/nix/install) --daemon
}

home_manager_switch() {
  local flake_ref="$1"
  local -a hm_cmd

  if has home-manager; then
    hm_cmd=(home-manager switch --flake "$flake_ref")
  else
    log "home-manager is not in PATH; using nix run fallback."
    hm_cmd=(nix run github:nix-community/home-manager -- switch --flake "$flake_ref")
  fi

  local switch_log
  switch_log="$(mktemp)"

  if "${hm_cmd[@]}" 2>&1 | tee "$switch_log"; then
    rm -f "$switch_log"
    return
  fi

  if grep -q 'An existing package already provides the following file:' "$switch_log"; then
    log "Detected a nix profile package conflict; removing conflicting profile entries and retrying once."

    local store_path
    while IFS= read -r store_path; do
      [[ -n "$store_path" ]] || continue
      nix profile remove "$store_path" >/dev/null 2>&1 || true
    done < <(
      grep -Eo '/nix/store/[[:alnum:]]{32}-[^"[:space:]]+' "$switch_log" \
        | sed -E 's#/(bin|lib|share|etc|include|sbin|libexec)/.*##' \
        | sort -u
    )

    nix profile remove home-manager-path >/dev/null 2>&1 || true
    "${hm_cmd[@]}"
    rm -f "$switch_log"
    return
  fi

  rm -f "$switch_log"
  return 1
}

darwin() {
  local casks=(
    ghostty
  )

  log "Updating Homebrew..."
  brew update

  log "Installing casks: ${casks[*]}"

  brew install --cask "${casks[@]}"

  ensure_nix

  log "Installing nix packages"

  home_manager_switch "$REPO_DIR/nix#CaseyStratton"
}

nixos() {
  log "Rebuilding NixOS configuration for $TARGET..."

  local flake="$REPO_DIR/nix#$TARGET"

  case "$LOCAL_HOST:$TARGET" in
    desktop:desktop)
      sudo nixos-rebuild switch --flake "$flake"
      ;;

    desktop:pi)
      nixos-rebuild switch --flake "$flake" --target-host casey@pi.local --sudo 
      ;;

    pi:*)
      sudo nixos-rebuild switch --flake "$flake" --build-host casey@desktop.local
      ;;

    *)
      abort "Unsupported rebuild path: local=$LOCAL_HOST target=$TARGET"
      ;;
  esac
}

build() {
  case "$OS" in
    darwin) darwin ;;
    linux) nixos ;;
    *) abort "Unsupported OS: $OS" ;;
  esac
}

update() {
  case "$OS" in
    linux)
      log "Updating NixOS flake..."
      nix flake update --flake "$REPO_DIR/nix"
      ;;
    *)
      has topgrade || abort "topgrade is not installed."
      topgrade
      ;;
  esac

  log "Update complete."
}

upgrade() {
  update
  build
}

case "$COMMAND" in
  build) build ;;
  update) update ;;
  upgrade) upgrade ;;
  *) abort "Usage: $0 [build|update|upgrade]" ;;
esac
